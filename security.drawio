        <mxCell id="oQbcHvXXmp1J8hQ4mMWe-7" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;labelBackgroundColor=default;labelBorderColor=default;textShadow=1;" value="&lt;div&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;b&gt;Service Mesh&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: start; font-family: &amp;quot;Segoe UI&amp;quot;; line-height: 20px;&quot;&gt;&lt;li style=&quot;&quot;&gt;&lt;p style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;strong style=&quot;&quot;&gt;Secure service-to-service communication&lt;/strong&gt; using &lt;strong style=&quot;&quot;&gt;mutual TLS (mTLS)&lt;/strong&gt;, along with &lt;strong style=&quot;&quot;&gt;identity-based authentication and authorization&lt;/strong&gt;.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;strong&gt;Automatic load balancing&lt;/strong&gt; for &lt;strong&gt;HTTP/HTTPS, gRPC, WebSocket, and TCP&lt;/strong&gt; traffic.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;strong&gt;Fine-grained traffic control&lt;/strong&gt; using rich routing rules, including &lt;strong&gt;retries, failover, and fault injection&lt;/strong&gt;.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;Support for &lt;strong&gt;robust access control, rate limiting&lt;/strong&gt;, and other &lt;strong&gt;extensible policy mechanisms&lt;/strong&gt;.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;p style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;strong style=&quot;&quot;&gt;Full observability&lt;/strong&gt; of all traffic within the cluster—including &lt;strong style=&quot;&quot;&gt;ingress and egress traffic&lt;/strong&gt;—with &lt;strong style=&quot;&quot;&gt;default metrics, log collection, and distributed tracing&lt;/strong&gt;.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="320" width="720" x="2100" y="2732.65" as="geometry" />
        </mxCell>
