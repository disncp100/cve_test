        <mxCell id="SPFEL0xErDc7T9kmHcFA-22" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;labelBackgroundColor=default;labelBorderColor=default;textShadow=1;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;CDN&lt;/font&gt;&lt;/h1&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;margin-bottom: 3pt; margin-left: 22pt; text-indent: -22pt; line-height: 18pt; background-image: none; background-position: 0% 0%; background-size: auto; background-repeat: repeat; background-attachment: scroll; background-origin: padding-box; background-clip: border-box;&quot;&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;font-family: Wingdings; color: rgb(24, 24, 24);&quot;&gt;l&lt;span style=&quot;font-style: normal; font-variant-caps: normal; font-width: normal; line-height: normal; font-family: &amp;quot;Times New Roman&amp;quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;&quot;&gt;&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;b&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;font-family: system-ui, serif; color: rgb(24, 24, 24);&quot;&gt;Access Control&lt;/span&gt;&lt;/b&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;font-family: system-ui, serif; color: rgb(24, 24, 24);&quot;&gt;: Referer-based hotlink protection, URL authentication, IP/User-Agent (UA) allowlist/denylist, and remote authentication&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;margin-bottom: 3pt; margin-left: 22pt; text-indent: -22pt; line-height: 18pt; background-image: none; background-position: 0% 0%; background-size: auto; background-repeat: repeat; background-attachment: scroll; background-origin: padding-box; background-clip: border-box;&quot;&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;font-family: Wingdings; color: rgb(24, 24, 24);&quot;&gt;l&lt;span style=&quot;font-style: normal; font-variant-caps: normal; font-width: normal; line-height: normal; font-family: &amp;quot;Times New Roman&amp;quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;&quot;&gt;&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;b&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;font-family: system-ui, serif; color: rgb(24, 24, 24);&quot;&gt;Attack Protection&lt;/span&gt;&lt;/b&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;font-family: system-ui, serif; color: rgb(24, 24, 24);&quot;&gt;:&lt;br&gt; Integration with DDoS Protection for large-scale attack mitigation, CC &lt;br&gt;attack protection via request rate limiting, and potential sandbox &lt;br&gt;isolation upon detection of abnormal traffic surges&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;margin-bottom: 3pt; margin-left: 22pt; text-indent: -22pt; line-height: 18pt; background-image: none; background-position: 0% 0%; background-size: auto; background-repeat: repeat; background-attachment: scroll; background-origin: padding-box; background-clip: border-box;&quot;&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;font-family: Wingdings; color: rgb(24, 24, 24);&quot;&gt;l&lt;span style=&quot;font-style: normal; font-variant-caps: normal; font-width: normal; line-height: normal; font-family: &amp;quot;Times New Roman&amp;quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;&quot;&gt;&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;b&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;font-family: system-ui, serif; color: rgb(24, 24, 24);&quot;&gt;Transport Security&lt;/span&gt;&lt;/b&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;font-family: system-ui, serif; color: rgb(24, 24, 24);&quot;&gt;: HTTPS encryption, TLS version control, HSTS, OCSP Stapling, and mutual TLS (client certificate authentication)&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;margin-bottom: 3pt; margin-left: 22pt; text-indent: -22pt; line-height: 18pt; background-image: none; background-position: 0% 0%; background-size: auto; background-repeat: repeat; background-attachment: scroll; background-origin: padding-box; background-clip: border-box;&quot;&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;font-family: Wingdings; color: rgb(24, 24, 24);&quot;&gt;l&lt;span style=&quot;font-style: normal; font-variant-caps: normal; font-width: normal; line-height: normal; font-family: &amp;quot;Times New Roman&amp;quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;&quot;&gt;&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;b&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;font-family: system-ui, serif; color: rgb(24, 24, 24);&quot;&gt;Origin Protection&lt;/span&gt;&lt;/b&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;font-family: system-ui, serif; color: rgb(24, 24, 24);&quot;&gt;:&lt;br&gt; Origin server IP is hidden; users must add Alibaba Cloud CDN’s &lt;br&gt;back-to-origin IP ranges to their origin firewall or WAF allowlist to &lt;br&gt;prevent blocking&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;margin-bottom: 3pt; margin-left: 22pt; text-indent: -22pt; line-height: 18pt; background-image: none; background-position: 0% 0%; background-size: auto; background-repeat: repeat; background-attachment: scroll; background-origin: padding-box; background-clip: border-box;&quot;&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;font-family: Wingdings; color: rgb(24, 24, 24);&quot;&gt;l&lt;span style=&quot;font-style: normal; font-variant-caps: normal; font-width: normal; line-height: normal; font-family: &amp;quot;Times New Roman&amp;quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;&quot;&gt;&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;b&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;font-family: system-ui, serif; color: rgb(24, 24, 24);&quot;&gt;&lt;/span&gt;&lt;/b&gt;&lt;/font&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;b&gt;Bot Management&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;" vertex="1">
