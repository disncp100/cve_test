        </mxCell>
        <mxCell id="SPFEL0xErDc7T9kmHcFA-16" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;labelBorderColor=default;labelBackgroundColor=default;textShadow=1;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;API Getaway&lt;/font&gt;&lt;/h1&gt;&lt;div style=&quot;font-family: &amp;quot;Segoe UI&amp;quot;; font-style: normal; font-weight: 400; line-height: 20px;&quot; align=&quot;left&quot;&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;strong&gt;Identity &amp;amp; Authentication&lt;/strong&gt;&lt;br&gt;Supports API Key, JWT, OAuth 2.0 / OIDC, mTLS, and multi‑auth mechanisms at the gateway layer.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;strong&gt;Authorization &amp;amp; Policy Control&lt;/strong&gt;&lt;br&gt;Fine‑grained access control based on policies, scopes, roles, JWT claims, API / version / endpoint.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;strong&gt;Traffic Protection&lt;/strong&gt;&lt;br&gt;Built‑in rate limiting, quotas, throttling, and abuse prevention (per API / consumer / endpoint).&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;strong&gt;Transport Security&lt;/strong&gt;&lt;br&gt;TLS termination and mutual TLS (mTLS) for secure client‑to‑API communication.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;strong&gt;Security Integration &amp;amp; Extensibility&lt;/strong&gt;&lt;br&gt;IP filtering, request validation, custom security plugins, and integration with WAF / Bot protection.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;strong&gt;Audit &amp;amp; Observability&lt;/strong&gt;&lt;br&gt;Centralized logging, metrics, and audit trails for API access and security events.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;p&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="433" width="890" x="710" y="1717" as="geometry" />
        </mxCell>
        <mxCell id="SPFEL0xErDc7T9kmHcFA-17" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;labelBackgroundColor=default;labelBorderColor=default;textShadow=1;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;SLB&lt;/h1&gt;&lt;div style=&quot;font-family: &amp;quot;Segoe UI&amp;quot;; font-style: normal; font-weight: 400; line-height: 20px;&quot; align=&quot;left&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;strong&gt;Network-layer Protection&lt;/strong&gt;&lt;br&gt;Built‑in basic DDoS protection and resilient L4/L7 traffic handling at the cloud edge. &lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;strong&gt;Transport Security&lt;/strong&gt;&lt;br&gt;HTTPS/TLS termination, support for TLS 1.2/1.3, certificate management, and configurable TLS security policies.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;strong&gt;Traffic Isolation &amp;amp; Exposure Control&lt;/strong&gt;&lt;br&gt;Public / internal SLB, VPC isolation, security group integration, and backend health checks to reduce attack surface.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;strong&gt;Security Service Integration&lt;/strong&gt;&lt;br&gt;Native integration with &lt;strong&gt;Alibaba Cloud WAF&lt;/strong&gt; (L7 attacks, bot protection) and &lt;strong&gt;Anti‑DDoS&lt;/strong&gt; services for volumetric attack mitigation.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;strong&gt;High Availability &amp;amp; Resilience&lt;/strong&gt;&lt;br&gt;Multi‑zone deployment and automatic failover to ensure service continuity under failure or attack scenarios. &lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="350" width="1190" x="1830" y="2210" as="geometry" />
        </mxCell>
        <mxCell id="SPFEL0xErDc7T9kmHcFA-18" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;labelBackgroundColor=default;labelBorderColor=default;textShadow=1;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Cloud Firewall&lt;br&gt;&lt;/h1&gt;&lt;p class=&quot;MsoListParagraphCxSpFirst&quot; style=&quot;margin-left:22.0pt;mso-add-space:&amp;lt;br/&amp;gt;auto;text-indent:-22.0pt;mso-list:l0 level1 lfo1&quot;&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;line-height: 115%; font-family: Wingdings;&quot;&gt;l&lt;span style=&quot;font-style: normal; font-variant-caps: normal; font-width: normal; line-height: normal; font-family: &amp;quot;Times New Roman&amp;quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-ligatures: normal; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-position: normal; font-feature-settings: normal; font-optical-sizing: auto; font-variation-settings: normal;&quot;&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;b&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;line-height: 15.333332px;&quot;&gt;Internet/VPC Boundary Firewall:&lt;/span&gt;&lt;/b&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;line-height: 15.333332px;&quot;&gt;&amp;nbsp;Enforces policies on all inbound/outbound public traffic&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p class=&quot;MsoListParagraphCxSpMiddle&quot; style=&quot;margin-left:22.0pt;mso-add-space:&amp;lt;br/&amp;gt;auto;text-indent:-22.0pt;mso-list:l0 level1 lfo1&quot;&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;line-height: 115%; font-family: Wingdings;&quot;&gt;l&lt;span style=&quot;font-style: normal; font-variant-caps: normal; font-width: normal; line-height: normal; font-family: &amp;quot;Times New Roman&amp;quot;; font-size-adjust: none; font-kerning: auto; font-variant-alternates: normal; font-variant-liga